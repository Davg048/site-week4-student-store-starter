// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Product: an item for sale in the store.
// Prisma field names are camelCase; @map / @@map point them at snake_case DB columns/tables.
model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String
  price       Float
  imageUrl    String? @map("image_url")
  category    String

  // Back-relation: one product can appear in many order items.
  orderItems  OrderItem[]

  @@map("products")
}

// Order: a single customer purchase. Order items get attached in Milestone 4.
model Order {
  id         Int      @id @default(autoincrement()) @map("order_id")
  customer   Int      @map("customer_id")
  email      String?
  totalPrice Float    @map("total_price")
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")

  // Back-relation: one order is made up of many order items.
  orderItems OrderItem[]

  @@map("orders")
}

// OrderItem: one line in an order — "this many of this product, at this price".
// Sits at the intersection of two relationships: it belongs to one Order AND one Product.
model OrderItem {
  id        Int   @id @default(autoincrement()) @map("order_item_id")
  orderId   Int   @map("order_id")
  productId Int   @map("product_id")
  quantity  Int
  price     Float

  // Foreign key to Order. Deleting the order cascades to (deletes) its items.
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Foreign key to Product. Deleting the product cascades to (deletes) items referencing it.
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}
